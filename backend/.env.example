# Anthropic — leave blank to run in STUB mode (no real LLM calls).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model selection. Production target is claude-opus-4-7 for accuracy,
# claude-sonnet-4-6 for cost, claude-haiku-4-5 for latency. See CURSOR-HANDOFF.md
# §"Open questions" — affects everything downstream.
ANTHROPIC_MODEL=claude-sonnet-4-6

PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Set to "1" to force stub responses even if ANTHROPIC_API_KEY is present.
# Useful when running the eval lab as a pure demo.
FORCE_STUB=0
